{
  "Storage": {
    "Provider": "S3",
    "LocalRoot": "App_Data/storage",
    "MaxUploadBytes": 20971520,
    "S3": {
      "ServiceUrl": "http://localhost:4566",
      "Bucket": "jira-clone",
      "AccessKey": "test",
      "SecretKey": "test",
      "ForcePathStyle": true,
      "Region": "us-east-1"
    }
  },
  "Database": {
    "Provider": "Postgres",
    "ConnectionString": "Host=localhost;Port=5432;Database=jira_clone;Username=jira_clone;Password=jira_clone",
    "EnableSensitiveDataLogging": true,
    "EnableDetailedErrors": true,
    "AutoMigrate": true
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "Email": {
    "Enabled": true,
    "Provider": "resend",
    "FromEmail": "onboarding@resend.dev"
  },
  "Resend": {
    "ApiKey": "",
    "BaseUrl": "https://api.resend.com"
  },
  "Jwt": {
    "SigningKey": "DEV_ONLY_DO_NOT_USE_IN_PROD__JIRA_CLONE_DEV_KEY_32B"
  },
  "E2E": {
    "NotifyUserEmail": ""
  }
}
